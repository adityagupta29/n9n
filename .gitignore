# n9n GitIgnore

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Dependencies (if we add package management later)
node_modules/
package-lock.json
yarn.lock

# Build files (if we add build process)
dist/
build/
.cache/

# Environment files
.env
.env.local
.env.*.local

# Test files
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
